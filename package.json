{
  "name": "@electricsheephq/smarter-claw",
  "version": "1.0.0-port.0",
  "description": "Smarter-Claw — Plan-Mode plugin for OpenClaw. v1 port-in-progress (P-1 skeleton). Source-of-truth parity at openclaw-pr70071-rebase tip ea04ea52c7.",
  "type": "module",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "tsc && cp openclaw.plugin.json dist/openclaw.plugin.json",
    "prepublishOnly": "npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "files": [
    "dist/src/",
    "openclaw.plugin.json",
    "README.md",
    "LICENSE",
    "TRADEMARK.md"
  ],
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^22.0.0",
    "openclaw": "2026.5.10-beta.5",
    "typescript": "^5.6.0",
    "vitest": "^3.2.0"
  },
  "peerDependencies": {
    "openclaw": ">=2026.5.10-beta.5"
  },
  "keywords": [
    "openclaw",
    "openclaw-plugin",
    "plan-mode",
    "agent",
    "claude-code",
    "codex",
    "gpt-5",
    "smarter-claw"
  ],
  "license": "SEE LICENSE IN LICENSE",
  "repository": {
    "type": "git",
    "url": "https://github.com/electricsheephq/Smarter-Claw.git"
  },
  "homepage": "https://github.com/electricsheephq/Smarter-Claw#readme",
  "bugs": {
    "url": "https://github.com/electricsheephq/Smarter-Claw/issues"
  },
  "openclaw": {
    "extensions": [
      "./dist/src/index.js"
    ]
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
